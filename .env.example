PORT=3000

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=11111111
DB_NAME=607
DB_CONNECTION_LIMIT=10
# Prisma CLI reads this when running `prisma generate` / `prisma db ...`.
DATABASE_URL=mysql://root:11111111@localhost:3306/607

SHOPLAZZA_STORE_DOMAIN=your-store.myshoplaza.com
SHOPLAZZA_ADMIN_TOKEN=your_admin_api_token
SHOPLAZZA_WEBHOOK_SECRET=your_webhook_secret
# Optional: 仅 Nest 服务（Webhook 验签、订阅、订单 API）使用的多店铺 JSON；与爬取任务分离。
# 未设置时回退到 SHOPLAZZA_STORES_JSON。
# SHOPLAZZA_WEBHOOK_STORES_JSON=[{"storeDomain":"store-a.myshoplaza.com","adminToken":"token_a","webhookSecret":"secret_a"}]
SHOPLAZZA_WEBHOOK_STORES_JSON=
# 兼容旧配置：未配置 SHOPLAZZA_WEBHOOK_STORES_JSON 时仍可用此项作为服务侧多店铺列表。
# SHOPLAZZA_STORES_JSON=[{"storeDomain":"store-a.myshoplaza.com","adminToken":"token_a","webhookSecret":"secret_a"},{"storeDomain":"store-b.myshoplaza.com","adminToken":"token_b","webhookSecret":"secret_b"}]
SHOPLAZZA_STORES_JSON=
# Python jobs/sync_shoplazza_order_fields.py：仅订单字段同步；未设置时回退 SHOPLAZZA_STORES_JSON（每项只需 storeDomain + adminToken）。
# SHOPLAZZA_CRAWL_STORES_JSON=[{"storeDomain":"store-a.myshoplaza.com","adminToken":"token_a"}]
SHOPLAZZA_CRAWL_STORES_JSON=
SHOPLAZZA_TIMEOUT_MS=10000
# Temporary bypass for TLS certificate validation (development only).
SHOPLAZZA_INSECURE_TLS=false
SHOPLAZZA_AUTO_SUBSCRIBE_WEBHOOK=true
SHOPLAZZA_API_VERSION=2020-07
SHOPLAZZA_WEBHOOK_CALLBACK_URL=https://your-domain.com/webhooks/shoplazza/orders/update
SHOPLAZZA_SUBSCRIBE_WEBHOOK_PATH_TEMPLATE=/openapi/{version}/webhooks/subscribe

# Change these if your Shoplazza API version/path differs.
SHOPLAZZA_CANCEL_ORDER_PATH_TEMPLATE=/admin/openapi/2020-07/orders/{orderId}/cancel.json
SHOPLAZZA_UPDATE_ORDER_PATH_TEMPLATE=/admin/openapi/2020-07/orders/{orderId}.json

