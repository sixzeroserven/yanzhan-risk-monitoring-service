PAYPAL_CLIENT_ID=Af2GsFYz-dAredpGTLcCHTh0mo-3qHlMIogVQfr2DONKKlSxnAtb_ES3mpkcU-rEOWNPqDNjwKIYvb_a
PAYPAL_CLIENT_SECRET=EPhRwYx96_MEkCRvdd6sKz7hE0mH5_1i8SO_glS1oHMB1q_b35Mq7MePpbtUTKKLK7XmP55cPog5Tu7M
# 生产环境默认 https://api-m.paypal.com；沙箱可改 https://api-m.sandbox.paypal.com
PAYPAL_BASE_URL=https://api-m.paypal.com
# 单账号兼容模式：指定该账号使用的静态住宅代理（requests HTTP/HTTPS/SOCKS proxy URL）
# PAYPAL_PROXY_URL=socks5h://proxy_user:proxy_password@proxy-host-a.example:12345
# 多 PayPal 账号推荐方式 1：JSON 数组。每个账号的 OAuth、Reporting、Disputes 请求都会走各自 proxy_url。
# PAYPAL_ACCOUNTS_JSON=[{"name":"paypal_a","client_id":"client_id_a","client_secret":"client_secret_a","proxy_url":"socks5h://proxy_user_a:proxy_password_a@proxy-a.example:12345"},{"name":"paypal_b","client_id":"client_id_b","client_secret":"client_secret_b","proxy_url":"socks5h://proxy_user_b:proxy_password_b@proxy-b.example:12345"}]
# 多 PayPal 账号推荐方式 2：账号 key + 分项变量。key 会转大写，非字母数字转下划线。
# PAYPAL_ACCOUNT_KEYS=paypal_a,paypal_b
# PAYPAL_PAYPAL_A_CLIENT_ID=client_id_a
# PAYPAL_PAYPAL_A_CLIENT_SECRET=client_secret_a
# PAYPAL_PAYPAL_A_PROXY_URL=socks5h://proxy_user_a:proxy_password_a@proxy-a.example:12345
# PAYPAL_PAYPAL_B_CLIENT_ID=client_id_b
# PAYPAL_PAYPAL_B_CLIENT_SECRET=client_secret_b
# PAYPAL_PAYPAL_B_PROXY_URL=socks5h://proxy_user_b:proxy_password_b@proxy-b.example:12345
PAYPAL_DISPUTE_LOOKBACK_DAYS=30
PAYPAL_DISPUTE_PAGE_SIZE=50
# Nest 定时任务：每天 21:00 同步最近 7 天 PayPal 争议数据（cron 格式，Asia/Shanghai）
# PAYPAL_DISPUTE_SYNC_CRON=00 21 * * *
# Disputes 请求超时与重试（代理链路偶发慢时避免整段任务直接失败）
# PAYPAL_DISPUTE_HTTP_CONNECT_TIMEOUT=30
# PAYPAL_DISPUTE_HTTP_READ_TIMEOUT=120
# PAYPAL_DISPUTE_HTTP_RETRIES=8
# PAYPAL_DISPUTE_HTTP_RETRY_BASE_DELAY_SECONDS=5
# PAYPAL_DISPUTE_RATE_LIMIT_BASE_DELAY_SECONDS=60
# PAYPAL_DISPUTE_RATE_LIMIT_MAX_DELAY_SECONDS=900
# PAYPAL_DISPUTE_DETAIL_DELAY_SECONDS=2
# PAYPAL_DISPUTE_DETAIL_HTTP_RETRIES=1
# PAYPAL_DISPUTE_DETAIL_READ_TIMEOUT=30
# PAYPAL_DISPUTE_DETAIL_FAILED_LOG=logs/paypal_dispute_detail_failed_ids.log
# PAYPAL_DISPUTE_STOP_DETAIL_ON_RATE_LIMIT=0
# jobs/sync_paypal_reporting_transactions.py：Reporting Transaction Search（与 disputes 共用 CLIENT_ID/SECRET/BASE_URL）
# PAYPAL_REPORTING_PAGE_SIZE=500
# 逗号分隔 T 码，覆盖脚本内置默认集合
# PAYPAL_REPORTING_EVENT_CODES=T1107,T1201
# 设为 1 时从默认集合去掉 T1300/T1301/T1302（授权量大）
# PAYPAL_REPORTING_EXCLUDE_AUTH_TCODES=1
# 无 CLI 日期时最多回溯天数（上限受 Reporting API 约 3 年窗口约束）
# PAYPAL_REPORTING_MAX_BACKFILL_DAYS=1095
# Reporting 允许的最早 start_date 距「当前」约多少天（默认 1095）
# PAYPAL_REPORTING_API_MAX_HISTORY_DAYS=1095
# PAYPAL_REPORTING_HTTP_READ_TIMEOUT=300
# PAYPAL_REPORTING_HTTP_CONNECT_TIMEOUT=30
# PAYPAL_REPORTING_HTTP_RETRIES=5
# Reporting 请求限速与 429 退避重试
# PAYPAL_REPORTING_REQUEST_DELAY_SECONDS=1
# PAYPAL_REPORTING_RATE_LIMIT_RETRIES=8
# PAYPAL_REPORTING_RATE_LIMIT_BASE_DELAY_SECONDS=60
# PAYPAL_REPORTING_RATE_LIMIT_MAX_DELAY_SECONDS=900
